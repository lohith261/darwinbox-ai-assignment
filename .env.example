# Application
APP_NAME=Agentic HR Workflow Engine
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Data stores
SQLITE_PATH=data/sqlite/app.db
CHROMA_PERSIST_DIRECTORY=data/chroma
CHROMA_COLLECTION_NAME=hr_policy_documents

# Policy corpus
POLICY_DOCUMENT_PATH=docs/hr_policy.md
POLICY_CHUNK_SIZE=900
POLICY_CHUNK_OVERLAP=150

# Frontend
STREAMLIT_SERVER_PORT=8501
BACKEND_BASE_URL=http://backend:8000
